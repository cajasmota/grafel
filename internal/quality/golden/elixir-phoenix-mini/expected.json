    { "name": "list_users", "kind": "SCOPE.Operation", "source_file": "lib/demo/user_repo.ex", "must_exist": true },
    { "name": "get_user!", "kind": "SCOPE.Operation", "source_file": "lib/demo/user_repo.ex", "must_exist": true },
