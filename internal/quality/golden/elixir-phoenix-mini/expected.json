    { "from_name": "index", "from_kind": "SCOPE.Operation", "from_file": "lib/demo_web/controllers/user_controller.ex",
      "kind": "CALLS", "to_name": "list_users", "to_kind": "SCOPE.Operation", "to_file": "lib/demo/user_repo.ex",
      "must_exist": true,
